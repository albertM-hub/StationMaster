build/
build_linux/
dist/
dist_linux/
*.spec.bak
__pycache__/
*.py[cod]
*.pyo

# Anciens .spec dupliqués (un seul .spec officiel : station_master_linux.spec)
StationMaster.spec
StationMaster_ON5AM.spec
StationMaster_linux.spec

# Backups locaux
Backups/
*.bak

# Logs
*.log

